{
  "mcpServers": {
    "dicelore-play": {
      "command": "npx",
      "args": ["tsx", "apps/orchestrator/eval/play-mcp.ts"],
      "env": {
        "DICELORE_PLAY_URL": "http://localhost:8787",
        "DICELORE_SESSIONS_DIR": ".dl-eval-doctrine"
      }
    },
    "dicelore-build": {
      "command": "npx",
      "args": ["tsx", "apps/orchestrator/eval/build-mcp.ts"],
      "env": {
        "DICELORE_PLAY_URL": "http://localhost:8787"
      }
    }
  }
}
